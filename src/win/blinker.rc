#include <windows.h>

#define IDI_APPICON 101

IDI_APPICON ICON "../../assets/blinker.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 0,1,0,0
 PRODUCTVERSION 0,1,0,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "041104b0"
        BEGIN
            VALUE "FileDescription", "Blinker Image Viewer"
            VALUE "FileVersion", "0.1.0"
            VALUE "InternalName", "blinker"
            VALUE "OriginalFilename", "blinker.exe"
            VALUE "ProductName", "Blinker"
            VALUE "ProductVersion", "0.1.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x411, 1200
    END
END
