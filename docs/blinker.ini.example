# Blinker 設定ファイル (blinker.exe と同じフォルダに blinker.ini として置く)
# 行頭 # または ; はコメント

[view]
# 背景色 (RRGGBB)
background = 202020
# タイトルバー・ステータスバーのテーマ: auto (OSのアプリテーマ設定に追従) / dark / light
theme = auto
# ステータスバー(画像情報・カーソル位置の座標と色・コピー通知)を表示するか
statusbar = true
# サイドバー(ファイル名一覧、Ctrl+Bでトグル)を起動時に表示するか
sidebar = false
# サイドバーの幅 (px, 120-480)
# 操作一覧 (F1) を出している間だけは、狭くても 300px まで広げて表示する
sidebar_width = 220
# 「F1 で操作一覧」の案内をステータスバーに数秒間出すか。
# 出るのは起動時と、どのコマンドにも割り当てられていないキーを押したとき
help_hint = true
# フィット表示時にウィンドウより小さい画像を拡大するか
fit_upscale = false
# 前後何枚を先読みするか (0-8)
prefetch_radius = 2
# [Linux/macOS (SDL版) のみ] UI フォントのファイルパス (.ttf/.ttc/.otf)。
# 未指定なら Noto CJK 等の既知のシステムフォントを自動探索する
# font_path = /usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc

[edit]
# 右ドラッグは「現在のツール」(トリミング / 矩形 / 楕円 / 矢印 / 直線 / テキスト)を
# その場で実行する。ツールの切り替えは何もない場所での右クリック(ドラッグなし)で
# 開くメニュー、または [keys] の tool_* コマンド。現在のツールはステータスバーに出る。
# 以下は新規作成時の初期値で、同じメニュー(線の太さ・文字サイズ・色の変更)から
# その場で変更できる。追加済みオブジェクトは左クリックで選択して移動・回転・
# 右クリックメニューで個別に変更できる
# 起動時のツール: crop / rect / ellipse / arrow / line / text
tool = rect
# 図形・テキストの色 (RRGGBB)
color = FF3B30
# 線の太さ (画面px基準, 1-100。表示ズームに合わせて画像へ換算される)
stroke_width = 3
# テキストの文字サイズ (画面px基準, 6-200)
font_size = 18
# テキストのフォント (フォントファミリ名。未指定なら Yu Gothic UI)
# メニューの候補にない名前も書ける。入っていない場合は代替フォントで描かれる
# font_family = Meiryo
# 矩形・楕円・テキストの塗りつぶし色 (RRGGBB)
fill_color = FFFFFF
# 塗りつぶしの不透明度 (0-255)。0 は塗らない = 下の画像が透けたまま
fill_alpha = 0
# テキストボックスの枠線色 (RRGGBB)
border_color = 000000
# テキストボックスの枠線幅 (画面px基準, 0-100)。0 は枠線なし
border_width = 0

[keys]
# コマンド = キー1, キー2, ... (記述したコマンドのデフォルトキーは置き換えられる)
# 修飾キーは Ctrl+ / Shift+ / Alt+。キー名の例:
#   Left Right Up Down Home End PageUp PageDown Space Enter Esc
#   Backspace Delete Tab Insert F1-F12 + - A-Z 0-9
#
# 使えるコマンド:
#   next prev first last zoom_in zoom_out fit actual_size
#   pan_left pan_right pan_up pan_down rotate_cw rotate_ccw
#   fullscreen open copy_image copy_path paste save_as undo delete_annotation
#   sidebar statusbar help escape quit
#   tool_crop tool_rect tool_ellipse tool_arrow tool_line tool_text
#     (右ドラッグで実行するツールの切り替え。既定のキーは割り当てていない)
#
# 例: Vim風の移動にする場合
#next = L, Right, Space
#prev = H, Left, Backspace
#
# 例: 注釈ツールをキーで切り替える場合(既定で使っていないキーを選ぶこと。
# 他コマンドが使っているキーを書くと、そちらのバインドが奪われる)
#tool_rect = X
#tool_arrow = A
#tool_text = T
